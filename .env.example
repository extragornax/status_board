# Site branding
SITE_TITLE=Status Board
SITE_URL=
FOOTER_TEXT=Powered by Status Board · Rust/Axum

# Monitoring
CHECK_INTERVAL_SECS=60
SERVICES_CONFIG=services.json

# Telegram alerts (optional — leave empty to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Admin reload endpoint (optional — leave empty to disable POST /api/reload)
ADMIN_TOKEN=

# Logging
RUST_LOG=info,status_board=info
